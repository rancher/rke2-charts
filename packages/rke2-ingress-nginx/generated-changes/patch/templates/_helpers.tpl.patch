+{{- printf "%s/" .Values.global.systemDefaultRegistry -}}
+{{- else -}}
+{{- "" -}}
+{{- end -}}
+{{- end -}}
+
+{{/*
+If the repository value is not hostname or IP with at least one dot, or host:port, use the systemDefaultRegistry if defined.
+*/}}
+{{- define "registry_domain_prefix" -}}
